#!/usr/bin/env sh
# Pre-push hook: enforce the Sonar coverage gate locally before code reaches CI.
# Runs the full test suite with coverage; fails the push if any threshold is missed.
#
# Bypass for hotfixes: SKIP_COVERAGE_CHECK=1 git push

if [ "${SKIP_COVERAGE_CHECK}" = "1" ]; then
  echo "[pre-push] Coverage check skipped (SKIP_COVERAGE_CHECK=1)"
  exit 0
fi

echo "[pre-push] Checking coverage thresholds (≥80% statements/lines/functions)..."
npm run test:coverage
